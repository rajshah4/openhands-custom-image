#!/usr/bin/env bash
set -euo pipefail

repo_root="${FINTECH_MONOREPO_ROOT:-/workspace/fintech-monorepo}"
seed_root="${FINTECH_MONOREPO_SEED_ROOT:-/opt/fintech-monorepo-seed}"

if [[ -f "$repo_root/package.json" && -d "$repo_root/tools" ]]; then
  exit 0
fi

if [[ ! -d "$seed_root" ]]; then
  echo "seed monorepo not found at $seed_root" >&2
  exit 1
fi

mkdir -p "$(dirname "$repo_root")"
rm -rf "$repo_root"
cp -R "$seed_root" "$repo_root"

echo "hydrated fintech monorepo to $repo_root"
